# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...но шаблон без секретов нужен в репозитории
!.env.example

# локальная база SQLite (данные восстанавливаются через prisma/seed.js)
prisma/*.db
prisma/*.db-journal

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
