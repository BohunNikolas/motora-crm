generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Car {
  id            String    @id @default(cuid())
  vin           String?   @unique  // нормализуется в uppercase (§8.1)
  make          String
  model         String
  year          Int
  erstzulassung DateTime? // первая регистрация (§8.1), опционально в дополнение к году
  mileage       Int
  color         String?
  transmission  String?
  fuel          String?
  leistung      Int?      // мощность, кВт (§8.1)
  voranmeldungen Int?     // число предыдущих владельцев; null = Unbekannt (§8.1)
  keysCount     Int?      // число ключей 0–10; null = Unbekannt (§8.1)
  purchaseDate  DateTime? // дата покупки (§8.1)
  engineVol     Float?    // legacy: скрыт из UI, поле оставлено (Требования §6.2)

  // Serviceheft (§8.2)
  serviceheft        String    @default("UNBEKANNT") // VOLLSTAENDIG|TEILWEISE|DIGITAL|NICHT_VORHANDEN|UNBEKANNT
  lastServiceDate    DateTime?
  lastServiceMileage Int?
  serviceComment     String?

  // Nachlackierungen (§8.3): перекрасы
  nachlackierungen        String   @default("UNBEKANNT") // JA|NEIN|UNBEKANNT
  nachlackierungenParts   String[] @default([])          // структурный список частей кузова
  nachlackierungenComment String?

  // Pickerl / §57a (§8.4)
  pickerlVorhanden String  @default("UNBEKANNT") // JA|NEIN|UNBEKANNT
  pickerlMonth     Int?    // Begutachtungsmonat 1–12
  pickerlYear      Int?    // Begutachtungsjahr
  pickerlComment   String?
  // Деньги — Decimal(12,2), EUR (Требования §2.7). Наследие Int переведено миграцией.
  purchasePrice Decimal   @db.Decimal(12, 2)
  listPrice     Decimal   @db.Decimal(12, 2)
  // 8 складских статусов (§6.1). PURCHASED|IN_TRANSIT|IN_PREPARATION|IN_SERVICE|
  // WAITING_FOR_PHOTOS|READY_FOR_SALE|RESERVED|SOLD (+ ARCHIVED — soft-delete, не витрина).
  status        String    @default("PURCHASED")
  notes         String?
  createdAt     DateTime  @default(now())

  // Парковочный учёт (§7). MH-код неизменяем, место можно менять.
  mhNumber      Int       @unique @default(autoincrement())
  parkingRow    String?   // одна латинская буква A–Z (uppercase)
  parkingSpot   Int?      // положительное целое
  parkingMoves  ParkingMove[]

  // Налоговый режим и канал закупки (§10).
  taxScheme     String    @default("DIFFERENZBESTEUERUNG") // DIFFERENZBESTEUERUNG | REGELBESTEUERUNG | UNGEKLAERT
  purchaseChannel String? // PRIVAT | AUKTION | HAENDLER | INZAHLUNGNAHME | IMPORT
  currentOwner  String    @default("MOTORHOF_OG") // MRIYA_MOTORS | A_MOTORS | AUTOHUB | MOTORHOF_OG (§9)

  // Финансовые поля (§11, §12, §13). Backfill существующих: einkauf24 = purchasePrice.
  einkaufspreisGemaess24 Decimal? @db.Decimal(12, 2)
  plannedSalePriceGross  Decimal? @db.Decimal(12, 2)
  minimumSalePriceGross  Decimal? @db.Decimal(12, 2)
  arrivalDate            DateTime?

  // Партнёрский владелец и внутренняя продажа e.U. → OG (§9). Значимы только,
  // когда currentOwner ∈ {MRIYA_MOTORS, A_MOTORS, AUTOHUB}; для MOTORHOF_OG — null.
  // Внутренний Verkaufspreis (actual ?? planned) = себестоимость MOTORHOF OG
  // (решение 20.07): результаты поставщика и OG считаются раздельно, не смешиваются.
  partnerPurchasePrice      Decimal?  @db.Decimal(12, 2) // первонач. закупочная цена поставщика (einkauf §24 поставщика)
  partnerAcquisitionCost    Decimal?  @db.Decimal(12, 2) // первонач. общая стоимость приобретения поставщика
  plannedInternalTransferPrice Decimal? @db.Decimal(12, 2) // планируемый внутр. Verkaufspreis e.U.→OG
  actualInternalTransferPrice  Decimal? @db.Decimal(12, 2) // фактический внутр. Verkaufspreis (= база OG)
  internalInvoiceNumber     String?   // номер внутреннего счёта
  internalInvoiceDate       DateTime? // дата внутреннего счёта
  internalInvoiceTaxScheme  String?   // режим внутр. счёта: DIFFERENZBESTEUERUNG | REGELBESTEUERUNG | UNGEKLAERT
  internalInvoicePaymentStatus String @default("OPEN") // OPEN | PAID — статус оплаты внутр. счёта
  // Продан партнёрский авто без подтверждённого фактического внутр. Verkaufspreis /
  // данных внутр. счёта → true (§9): «ожидает внутренний счёт», явная незавершённость.
  awaitingInternalInvoice   Boolean   @default(false)

  // Условные поля закупки по каналам (§11). Значимы только для соответствующего
  // purchaseChannel; поля других каналов зануляются (channelDataFromForm).
  // Auktion (§11.2): базой приобретения OG служит auctionInvoiceTotal, §24 — Fahrzeugpreis.
  auctionVehiclePrice   Decimal? @db.Decimal(12, 2) // Fahrzeugpreis
  auctionFeeNet         Decimal? @db.Decimal(12, 2) // Auktionsgebühr netto
  auctionFeeVat         Decimal? @db.Decimal(12, 2) // USt на комиссию (brutto = netto + USt)
  auctionTransportCost  Decimal? @db.Decimal(12, 2) // Transportkosten
  auctionOtherFees      Decimal? @db.Decimal(12, 2) // Sonstige Gebühren
  auctionInvoiceTotal   Decimal? @db.Decimal(12, 2) // Auktionsrechnung gesamt — полная фактическая оплата
  auctionInvoiceNumber  String?
  auctionSupplier       String?
  auctionCountry        String?
  // Продано auktion-авто с gesamt < Fahrzeugpreis — только admin override с причиной (§11.2).
  // Händler (§11.3)
  haendlerSupplier             String?
  haendlerInvoiceNumber        String?
  haendlerInvoiceDate          DateTime?
  haendlerPurchaseNet          Decimal? @db.Decimal(12, 2)
  haendlerPurchaseVat          Decimal? @db.Decimal(12, 2)
  haendlerPurchaseGross        Decimal? @db.Decimal(12, 2)
  haendlerVorsteuerAusgewiesen Boolean  @default(false) // выделена ли Vorsteuer
  // Inzahlungnahme (§11.4). Клиент и связанная продажа — в фазе 3e (Sale).
  tradeInEstimatedValue Decimal? @db.Decimal(12, 2) // оценочная стоимость принятого авто
  tradeInCreditValue    Decimal? @db.Decimal(12, 2) // зачётная стоимость (база приобретения OG)
  tradeInSurcharge      Decimal? @db.Decimal(12, 2) // доплата (положит.)
  tradeInSurchargeBy    String?  // CLIENT | MOTORHOF — кто доплачивает
  // Import (§11.5). Юридическое решение о Differenzbesteuerung НЕ автоматизируем — при
  // нехватке данных taxScheme = UNGEKLAERT. FX-пересчёт валюты — справочно (базой служит EUR).
  importCountry       String?
  importZone          String?  // EU | DRITTLAND
  importCurrency      String?  // ISO-код исходной валюты (EUR = без пересчёта)
  importExchangeRate  Decimal? @db.Decimal(12, 6) // курс исходной валюты к EUR
  importInvoiceAmount Decimal? @db.Decimal(12, 2) // сумма счёта в исходной валюте
  importTransportCost Decimal? @db.Decimal(12, 2)
  importZoll          Decimal? @db.Decimal(12, 2) // пошлина
  importEust          Decimal? @db.Decimal(12, 2) // Einfuhrumsatzsteuer
  importNova          Decimal? @db.Decimal(12, 2) // NoVA
  importOtherCosts    Decimal? @db.Decimal(12, 2)

  expenses      Expense[]
  deals         Deal[]
  tasks         Task[]
  files         CarFile[]
  sales         Sale[]
}

// Бронь и продажа автомобиля (§18). Единый жизненный цикл: RESERVED → COMPLETED
// (продано) либо CANCELLED (soft — не удаляем физически, §21). Одна активная Sale
// на авто; новый покупатель = новая запись. Источник истины по продажам (реш. 20.07):
// KPI дашборда «Продано/Маржа» считаются по Sale, воронка Deal остаётся для лидов.
model Sale {
  id        String   @id @default(cuid())
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  carId     String
  client    Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  clientId  String?
  stage     String   @default("RESERVED") // RESERVED | COMPLETED | CANCELLED

  // Бронь (§18.1)
  reservedAt               DateTime?
  reservationExpiresAt     DateTime?
  anzahlung                Decimal?  @db.Decimal(12, 2)
  reservationPaymentMethod String?
  reservationComment       String?

  // Продажа (§18.2)
  actualSalePriceGross Decimal?  @db.Decimal(12, 2)
  saleDate             DateTime?
  paymentStatus        String?   // OPEN | PARTIAL | PAID
  paymentMethod        String?   // CASH | TRANSFER | FINANCING | CARD
  deliveryDate         DateTime?
  mileageAtSale        Int?
  saleCategory         String?   // B2C | B2B | EXPORT
  taxSchemeSnapshot    String?   // режим на момент продажи
  employee             User?     @relation(fields: [employeeUserId], references: [id], onDelete: SetNull)
  employeeUserId       String?

  // Financial snapshot (§18.2): заморожен на момент продажи — последующая смена
  // настроек ставки НЕ меняет историческую продажу.
  financialSnapshot Json?

  // Связь с исходным Deal при миграции (§22) — @unique для идемпотентности.
  legacyDealId String? @unique

  createdAt   DateTime  @default(now())
  cancelledAt DateTime?

  @@index([carId])
  @@index([stage])
}

// Фото и документы авто (§8.5). Хранятся в R2 (ключ `key`), отдаются
// через /api/files/[id] с проверкой прав.
model CarFile {
  id          String   @id @default(cuid())
  car         Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  carId       String
  kind        String   // PHOTO | DOCUMENT
  docType     String?  // для DOCUMENT: KAUFVERTRAG | ZULASSUNG | GUTACHTEN_57A | AUKTIONSRECHNUNG | RECHNUNG_EU_OG | ANKAUFSRECHNUNG | UEBERGABE | SONSTIGES
  key         String   // ключ объекта в хранилище
  filename    String
  contentType String
  size        Int
  uploadedBy  String?
  createdAt   DateTime @default(now())

  @@index([carId])
}

// История перемещений по парковке (§7): кто, когда, откуда и куда.
model ParkingMove {
  id        String   @id @default(cuid())
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  carId     String
  fromRow   String?
  fromSpot  Int?
  toRow     String?
  toSpot    Int?
  movedAt   DateTime @default(now())
  userId    String?

  @@index([carId])
}

model Expense {
  id     String   @id @default(cuid())
  title  String
  // Колонка в БД остаётся "amount" (@map) — переименования нет, данные сохранены.
  amountGross Decimal @db.Decimal(12, 2) @map("amount")
  amountNet   Decimal? @db.Decimal(12, 2)
  vatRate     Int      @default(20)
  deductibleInputVatAmount Decimal? @db.Decimal(12, 2)
  // Уже входит в полную стоимость приобретения — не вычитать второй раз (§12.1).
  alreadyIncludedInAcquisitionCost Boolean @default(false)
  // Kostenvoranschlag-процесс: смета TECHNICAL создаётся PENDING и не входит
  // в маржу, пока PARTNER/ADMIN не подтвердит (roles-motorhof.md). Существующие — APPROVED.
  approvalStatus String @default("APPROVED") // PENDING | APPROVED
  date   DateTime @default(now())
  car    Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  carId  String
}

// ─── Аккаунты и аудит (фаза 2) ─────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String   // scrypt: "salt:hash" (hex)
  // Мульти-роли: права = union капабилити всех ролей (roles-motorhof.md).
  roles        String[] @default([]) // ADMIN | PARTNER | SALES | TECHNICAL | READ_ONLY
  mustChangePassword Boolean @default(true)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  sessions     Session[]
  auditLogs    AuditLog[]
  sales        Sale[]
}

model Session {
  token     String   @id // случайные 32 байта hex
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  entityType String   // Car | Expense | Deal | Client | Task | User
  entityId   String
  action     String   // create | update | delete | status | approve | override…
  before     Json?
  after      Json?
  reason     String?  // для override — обязательный комментарий
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId     String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

model Client {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String?
  type      String   @default("BUYER") // BUYER | SELLER | BOTH
  source    String?  // авито, авто.ру, рекомендация, сайт, проходящий
  notes     String?
  createdAt DateTime @default(now())
  deals     Deal[]
  tasks     Task[]
  sales     Sale[]
}

model Deal {
  id        String    @id @default(cuid())
  type      String    @default("SALE") // SALE | PURCHASE | TRADE_IN
  stage     String    @default("NEW") // NEW | CONTACT | TEST_DRIVE | NEGOTIATION | CONTRACT | DONE | LOST
  amount    Decimal?  @db.Decimal(12, 2)
  notes     String?
  createdAt DateTime  @default(now())
  closedAt  DateTime?
  car       Car?      @relation(fields: [carId], references: [id], onDelete: SetNull)
  carId     String?
  client    Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId  String
  tasks     Task[]
}

model Task {
  id        String    @id @default(cuid())
  title     String
  dueDate   DateTime?
  done      Boolean   @default(false)
  createdAt DateTime  @default(now())
  car       Car?      @relation(fields: [carId], references: [id], onDelete: SetNull)
  carId     String?
  client    Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  clientId  String?
  deal      Deal?     @relation(fields: [dealId], references: [id], onDelete: SetNull)
  dealId    String?
}
