generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Car {
  id            String    @id @default(cuid())
  vin           String?
  make          String
  model         String
  year          Int
  mileage       Int
  color         String?
  transmission  String?
  fuel          String?
  engineVol     Float?
  purchasePrice Int
  listPrice     Int
  status        String    @default("PREP") // PREP | AVAILABLE | RESERVED | SOLD
  notes         String?
  createdAt     DateTime  @default(now())
  expenses      Expense[]
  deals         Deal[]
  tasks         Task[]
}

model Expense {
  id     String   @id @default(cuid())
  title  String
  amount Int
  date   DateTime @default(now())
  car    Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  carId  String
}

model Client {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String?
  type      String   @default("BUYER") // BUYER | SELLER | BOTH
  source    String?  // авито, авто.ру, рекомендация, сайт, проходящий
  notes     String?
  createdAt DateTime @default(now())
  deals     Deal[]
  tasks     Task[]
}

model Deal {
  id        String    @id @default(cuid())
  type      String    @default("SALE") // SALE | PURCHASE | TRADE_IN
  stage     String    @default("NEW") // NEW | CONTACT | TEST_DRIVE | NEGOTIATION | CONTRACT | DONE | LOST
  amount    Int?
  notes     String?
  createdAt DateTime  @default(now())
  closedAt  DateTime?
  car       Car?      @relation(fields: [carId], references: [id], onDelete: SetNull)
  carId     String?
  client    Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId  String
  tasks     Task[]
}

model Task {
  id        String    @id @default(cuid())
  title     String
  dueDate   DateTime?
  done      Boolean   @default(false)
  createdAt DateTime  @default(now())
  car       Car?      @relation(fields: [carId], references: [id], onDelete: SetNull)
  carId     String?
  client    Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  clientId  String?
  deal      Deal?     @relation(fields: [dealId], references: [id], onDelete: SetNull)
  dealId    String?
}
