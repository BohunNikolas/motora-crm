# Скопируйте в .env и заполните. Файл .env в git не попадает.

# Строка подключения к Postgres (Neon).
# Берётся в панели Neon → Connection string. Обязательно с ?sslmode=require
DATABASE_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# ФАЗА 2: общий пароль APP_PASSWORD больше НЕ используется.
# Вход — по личным аккаунтам (таблица User). Создание пользователей:
#   node prisma/seed-users.mjs
# Скрипт печатает временные пароли; при первом входе система требует их сменить.
